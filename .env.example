# StarMaker Credentials
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git!
#
# Credential loading priority:
#   1. Environment variables (highest - for CI/CD)
#   2. .env file (this file, for local development)
#   3. ~/.starmaker/credentials.yaml (legacy, backward compatible)

# Reddit — Create app at https://www.reddit.com/prefs/apps/ (select "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Dev.to — Get API key at https://dev.to/settings/extensions
DEVTO_API_KEY=

# Twitter/X — Get keys at https://developer.twitter.com/en/portal/dashboard
# Note: Twitter API v2 requires a paid Basic plan ($100/mo)
# Leave blank to use free browser intent instead
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=

# Discord — Create webhooks at Server Settings > Integrations > Webhooks
# For multiple webhooks, separate URLs with commas
DISCORD_WEBHOOK_URLS=
